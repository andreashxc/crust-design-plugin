{
  "id": "01KQ3A00000000000000000001",
  "name": "Acceptance banner",
  "author": "designer1",
  "description": "Composable ya.ru banner with multiple tweak controls for acceptance smoke",
  "scope": {
    "match": [
      "*://*.ya.ru/*",
      "*://ya.ru/*"
    ]
  },
  "world": "isolated",
  "tweaks": [
    {
      "type": "text",
      "key": "headline",
      "label": "Headline",
      "default": "Designer1 acceptance banner"
    },
    {
      "type": "select",
      "key": "density",
      "label": "Density",
      "options": [
        "compact",
        "comfortable"
      ],
      "default": "compact"
    },
    {
      "type": "color",
      "key": "accent",
      "label": "Accent",
      "default": "#2563eb"
    },
    {
      "type": "toggle",
      "key": "show_timestamp",
      "label": "Show timestamp",
      "default": true
    }
  ]
}
