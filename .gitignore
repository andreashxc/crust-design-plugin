node_modules/
apps/extension/.output/
apps/extension/.wxt/
dist/
coverage/
*.log
*.tsbuildinfo
.DS_Store
.env
.env.local

# Keep public forks clean: only curated examples are tracked by default.
# Personal/client experiments under experiments/<author>/ stay local unless
# intentionally force-added.
experiments/*
!experiments/.gitkeep
!experiments/examples/
!experiments/examples/**

# Site design context can contain reverse-engineered/client-specific details.
# Keep local DESIGN.md files private unless intentionally force-added.
DESIGN.md
design-context/*
!design-context/
!design-context/README.md
.crust/design-context/
