{
  "name": "designer-experiment-platform",
  "version": "0.0.0",
  "private": true,
  "license": "GPL-3.0-only",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "corepack pnpm -F @platform/extension dev",
    "build": "corepack pnpm -r build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc -b --pretty",
    "test": "vitest",
    "check-csp": "tsx scripts/check-csp.ts",
    "create-experiment": "tsx scripts/create-experiment.ts",
    "fork-experiment": "tsx scripts/fork-experiment.ts",
    "generate-descriptions": "tsx scripts/generate-descriptions.ts",
    "design-context": "tsx scripts/design-context.ts",
    "save-preset": "tsx scripts/save-preset.ts",
    "package:chrome": "corepack pnpm build && corepack pnpm -F @platform/extension zip && cd apps/extension/.output && rm -f crust-chrome-mv3-unpacked.zip && zip -qr crust-chrome-mv3-unpacked.zip chrome-mv3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@vitest/ui": "^4.1.5",
    "esbuild": "^0.28.0",
    "glob": "^11.1.0",
    "lefthook": "^2.1.6",
    "tsx": "^4.20.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
